<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="config_expiration_alert_days" model="ir.config_parameter">
            <field name="key">afr_ecm.expiration_alert_days</field>
            <field name="value">30,7,0</field>
        </record>

        <record id="config_ocr_enabled" model="ir.config_parameter">
            <field name="key">afr_ecm.ocr.enabled</field>
            <field name="value">True</field>
        </record>
        <record id="config_ocr_languages" model="ir.config_parameter">
            <field name="key">afr_ecm.ocr.languages</field>
            <field name="value">por+eng</field>
        </record>
        <record id="config_ocr_max_pages" model="ir.config_parameter">
            <field name="key">afr_ecm.ocr.max_pages</field>
            <field name="value">50</field>
        </record>
        <record id="config_ocr_min_chars_skip" model="ir.config_parameter">
            <field name="key">afr_ecm.ocr.min_chars_skip</field>
            <field name="value">100</field>
        </record>
        <record id="config_ocr_dpi" model="ir.config_parameter">
            <field name="key">afr_ecm.ocr.dpi</field>
            <field name="value">200</field>
        </record>

        <!-- Acelera o cron padrão do queue_job_cron_jobrunner (default OCA = 1 dia).
             noupdate=1 do queue_job_cron_jobrunner não bloqueia este record pois
             usamos a ref do módulo; sobrescreve interval. -->
        <record id="queue_job_cron_jobrunner.queue_job_cron" model="ir.cron">
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
        </record>

        <record id="cron_ocr_backlog" model="ir.cron">
            <field name="name">AFR ECM: reenfileira jobs OCR pendentes/falhos</field>
            <field name="model_id" ref="dms.model_dms_file"/>
            <field name="state">code</field>
            <field name="code">model._cron_ocr_backlog()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>

        <record id="cron_check_expirations" model="ir.cron">
            <field name="name">AFR ECM: verificar vencimento de documentos</field>
            <field name="model_id" ref="dms.model_dms_file"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_expirations()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
