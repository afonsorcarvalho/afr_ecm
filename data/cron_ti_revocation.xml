<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="cron_ti_revocation_escalation" model="ir.cron">
            <field name="name">AFR ECM — Revogação Acesso TI (escalação 4h)</field>
            <field name="model_id" ref="dms.model_dms_file"/>
            <field name="state">code</field>
            <field name="code">model._cron_pending_revocations_escalate()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(minutes=10)).strftime('%Y-%m-%d %H:%M:00')"/>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
