<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_afr_ecm_nc" model="ir.sequence">
            <field name="name">ECM NC Sequence</field>
            <field name="code">afr.ecm.nc</field>
            <field name="prefix">NC/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="use_date_range" eval="True"/>
        </record>

        <record id="seq_afr_ecm_capa" model="ir.sequence">
            <field name="name">ECM CAPA Sequence</field>
            <field name="code">afr.ecm.capa</field>
            <field name="prefix">CAPA/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="use_date_range" eval="True"/>
        </record>
    </data>
</odoo>
