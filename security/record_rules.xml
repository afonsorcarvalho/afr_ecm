<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="rule_dms_file_public" model="ir.rule">
            <field name="name">DMS File: público leitura geral</field>
            <field name="model_id" ref="dms.model_dms_file"/>
            <field name="domain_force">[('confidentiality','=','public')]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="rule_dms_file_internal" model="ir.rule">
            <field name="name">DMS File: interno → grupo ECM Usuário</field>
            <field name="model_id" ref="dms.model_dms_file"/>
            <field name="domain_force">[('confidentiality','=','internal')]</field>
            <field name="groups" eval="[(4, ref('group_ecm_user'))]"/>
        </record>

        <record id="rule_dms_file_restricted" model="ir.rule">
            <field name="name">DMS File: restrito → dono ou gestor</field>
            <field name="model_id" ref="dms.model_dms_file"/>
            <field name="domain_force">['|', ('create_uid','=',user.id), ('confidentiality','!=','restricted')]</field>
            <field name="groups" eval="[(4, ref('group_ecm_user'))]"/>
        </record>

        <record id="rule_dms_file_restricted_manager" model="ir.rule">
            <field name="name">DMS File: restrito → gestor vê tudo</field>
            <field name="model_id" ref="dms.model_dms_file"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('group_ecm_manager'))]"/>
        </record>

        <record id="rule_dms_file_confidential" model="ir.rule">
            <field name="name">DMS File: confidencial → apenas gestor/dono</field>
            <field name="model_id" ref="dms.model_dms_file"/>
            <field name="domain_force">['|', ('create_uid','=',user.id), ('confidentiality','!=','confidential')]</field>
            <field name="groups" eval="[(4, ref('group_ecm_user'))]"/>
        </record>
    </data>
</odoo>
