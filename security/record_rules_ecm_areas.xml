<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="rule_ecm_rh_funcionario_own" model="ir.rule">
            <field name="name">DMS File: RH Funcionário → acesso próprio dossiê</field>
            <field name="model_id" ref="dms.model_dms_file"/>
            <field name="domain_force">[('directory_id.complete_name', 'ilike', user.login)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('afr_ecm.group_ecm_area_rh_funcionario'))]"/>
        </record>

        <record id="rule_ecm_auditor_externo_readonly" model="ir.rule">
            <field name="name">DMS File: Auditor Externo → leitura apenas</field>
            <field name="model_id" ref="dms.model_dms_file"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('afr_ecm.group_ecm_area_auditor'))]"/>
        </record>
    </data>
</odoo>
