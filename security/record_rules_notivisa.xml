<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================
             afr.ecm.notivisa — NOTIVISA (Tecnovigilância)
             ============================================================ -->

        <!-- All ECM users: read-only access -->
        <record id="rule_afr_ecm_notivisa_user_read" model="ir.rule">
            <field name="name">NOTIVISA: leitura geral usuários ECM</field>
            <field name="model_id" ref="model_afr_ecm_notivisa"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('afr_ecm.group_ecm_user'))]"/>
        </record>

        <!-- Área Regulatório: read + write + create (primary owner) -->
        <record id="rule_afr_ecm_notivisa_regulatorio_write" model="ir.rule">
            <field name="name">NOTIVISA: escrita Área Regulatório</field>
            <field name="model_id" ref="model_afr_ecm_notivisa"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('afr_ecm.group_ecm_area_regulatorio'))]"/>
        </record>

        <!-- Área Operação: read + write + create (initiates events) -->
        <record id="rule_afr_ecm_notivisa_operacao_write" model="ir.rule">
            <field name="name">NOTIVISA: escrita Área Operação</field>
            <field name="model_id" ref="model_afr_ecm_notivisa"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('afr_ecm.group_ecm_area_operacao'))]"/>
        </record>

        <!-- ECM Manager: full access including unlink -->
        <record id="rule_afr_ecm_notivisa_manager_full" model="ir.rule">
            <field name="name">NOTIVISA: Gestor ECM acesso total</field>
            <field name="model_id" ref="model_afr_ecm_notivisa"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
            <field name="groups" eval="[(4, ref('afr_ecm.group_ecm_manager'))]"/>
        </record>

    </data>
</odoo>
