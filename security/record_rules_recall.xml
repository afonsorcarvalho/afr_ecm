<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================
             afr.ecm.recall — Recall (Recuperação de Lote)
             ============================================================ -->
        <record id="rule_afr_ecm_recall_user_read" model="ir.rule">
            <field name="name">Recall: leitura geral usuários ECM</field>
            <field name="model_id" ref="model_afr_ecm_recall"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('afr_ecm.group_ecm_user'))]"/>
        </record>

        <record id="rule_afr_ecm_recall_operacao_write" model="ir.rule">
            <field name="name">Recall: escrita Área Operação</field>
            <field name="model_id" ref="model_afr_ecm_recall"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('afr_ecm.group_ecm_area_operacao'))]"/>
        </record>

        <record id="rule_afr_ecm_recall_sgq_write" model="ir.rule">
            <field name="name">Recall: escrita Área SGQ</field>
            <field name="model_id" ref="model_afr_ecm_recall"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('afr_ecm.group_ecm_area_sgq'))]"/>
        </record>

        <record id="rule_afr_ecm_recall_manager_full" model="ir.rule">
            <field name="name">Recall: Gestor ECM acesso total</field>
            <field name="model_id" ref="model_afr_ecm_recall"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
            <field name="groups" eval="[(4, ref('afr_ecm.group_ecm_manager'))]"/>
        </record>

    </data>
</odoo>
