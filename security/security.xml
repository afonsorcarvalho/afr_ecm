<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_category_ecm" model="ir.module.category">
            <field name="name">ECM</field>
            <field name="description">Enterprise Content Management</field>
            <field name="sequence">20</field>
        </record>

        <record id="group_ecm_user" model="res.groups">
            <field name="name">ECM / Usuário</field>
            <field name="category_id" ref="module_category_ecm"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('dms.group_dms_user'))]"/>
        </record>

        <record id="group_ecm_manager" model="res.groups">
            <field name="name">ECM / Gestor</field>
            <field name="category_id" ref="module_category_ecm"/>
            <field name="implied_ids" eval="[(4, ref('group_ecm_user')), (4, ref('dms.group_dms_manager'))]"/>
        </record>

        <record id="group_ecm_admin" model="res.groups">
            <field name="name">ECM / Administrador</field>
            <field name="category_id" ref="module_category_ecm"/>
            <field name="implied_ids" eval="[(4, ref('group_ecm_manager'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
