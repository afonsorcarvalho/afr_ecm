<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_audit_log_tree" model="ir.ui.view">
        <field name="name">afr.ecm.audit.log.tree</field>
        <field name="model">afr.ecm.audit.log</field>
        <field name="arch" type="xml">
            <tree create="0" edit="0" delete="0">
                <field name="create_date"/>
                <field name="user_id"/>
                <field name="event_type"/>
                <field name="model"/>
                <field name="res_id"/>
                <field name="res_name"/>
                <field name="ip"/>
            </tree>
        </field>
    </record>

    <record id="view_audit_log_form" model="ir.ui.view">
        <field name="name">afr.ecm.audit.log.form</field>
        <field name="model">afr.ecm.audit.log</field>
        <field name="arch" type="xml">
            <form create="0" edit="0">
                <sheet>
                    <group>
                        <group>
                            <field name="create_date"/>
                            <field name="user_id"/>
                            <field name="ip"/>
                        </group>
                        <group>
                            <field name="event_type"/>
                            <field name="model"/>
                            <field name="res_id"/>
                            <field name="res_name"/>
                            <field name="record_ref"/>
                        </group>
                    </group>
                    <group string="Detalhes">
                        <field name="details" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_audit_log_search" model="ir.ui.view">
        <field name="name">afr.ecm.audit.log.search</field>
        <field name="model">afr.ecm.audit.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="user_id"/>
                <field name="model"/>
                <field name="res_id"/>
                <field name="event_type"/>
                <filter name="today" string="Hoje" domain="[('create_date','&gt;=', context_today().strftime('%Y-%m-%d 00:00:00'))]"/>
                <filter name="ev_create" string="Criação" domain="[('event_type','=','create')]"/>
                <filter name="ev_write" string="Alteração" domain="[('event_type','=','write')]"/>
                <filter name="ev_unlink" string="Exclusão" domain="[('event_type','=','unlink')]"/>
                <filter name="ev_view" string="Visualização" domain="[('event_type','=','view')]"/>
                <filter name="ev_download" string="Download" domain="[('event_type','=','download')]"/>
                <filter name="ev_acl" string="Permissão" domain="[('event_type','=','acl_change')]"/>
                <group expand="0" string="Agrupar Por">
                    <filter name="g_user" string="Usuário" context="{'group_by':'user_id'}"/>
                    <filter name="g_event" string="Evento" context="{'group_by':'event_type'}"/>
                    <filter name="g_model" string="Modelo" context="{'group_by':'model'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_audit_log" model="ir.actions.act_window">
        <field name="name">Auditoria ECM</field>
        <field name="res_model">afr.ecm.audit.log</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_audit_log_search"/>
    </record>
</odoo>
