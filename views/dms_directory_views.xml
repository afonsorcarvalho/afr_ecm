<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dms_directory_form_ecm" model="ir.ui.view">
        <field name="name">dms.directory.form.ecm</field>
        <field name="model">dms.directory</field>
        <field name="inherit_id" ref="dms.view_dms_directory_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="ECM" name="ecm">
                    <group>
                        <field name="default_document_type_id"/>
                    </group>
                </page>
                <page string="Manual da Pasta" name="ecm_manual">
                    <field name="description"
                           widget="html"
                           placeholder="Descreva o que vai nesta pasta: escopo, norma de referência, exemplos típicos de arquivos, nomenclatura esperada, onde NÃO colocar, confidencialidade default..."/>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
