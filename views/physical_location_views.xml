<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_phys_loc_tree" model="ir.ui.view">
        <field name="name">afr.ecm.physical.location.tree</field>
        <field name="model">afr.ecm.physical.location</field>
        <field name="arch" type="xml">
            <tree>
                <field name="complete_path"/>
                <field name="code"/>
                <field name="location_type"/>
                <field name="barcode"/>
                <field name="file_count"/>
            </tree>
        </field>
    </record>

    <record id="view_phys_loc_form" model="ir.ui.view">
        <field name="name">afr.ecm.physical.location.form</field>
        <field name="model">afr.ecm.physical.location</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_print_label" type="object" string="Imprimir Etiqueta QR" class="oe_highlight"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_files" type="object" class="oe_stat_button" icon="fa-files-o">
                            <field name="file_count" widget="statinfo" string="Arquivos"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Arquivado" bg_color="bg-danger" attrs="{'invisible': [('active','=',True)]}"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Ex.: Caixa 001"/></h1>
                        <h3><field name="complete_path" readonly="1"/></h3>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="location_type"/>
                            <field name="parent_id"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="barcode"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="qr_image" widget="image" options="{'size': [120, 120]}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Filhos" name="children">
                            <field name="child_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="location_type"/>
                                    <field name="barcode"/>
                                    <field name="file_count"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Observações" name="note">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_phys_loc_search" model="ir.ui.view">
        <field name="name">afr.ecm.physical.location.search</field>
        <field name="model">afr.ecm.physical.location</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="barcode"/>
                <field name="parent_id"/>
                <filter name="archived" string="Arquivados" domain="[('active','=',False)]"/>
                <group expand="0" string="Agrupar Por">
                    <filter name="group_type" string="Tipo" context="{'group_by': 'location_type'}"/>
                    <filter name="group_parent" string="Pai" context="{'group_by': 'parent_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_phys_loc" model="ir.actions.act_window">
        <field name="name">Localizações Físicas</field>
        <field name="res_model">afr.ecm.physical.location</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_phys_loc_search"/>
    </record>
</odoo>
